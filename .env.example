# API mode for scripts/run_strategy_pipeline.py
# Shared by scripts/pure_jade_api.py, run_strategy_pipeline.py,
# run_strategy_pipeline_v021.py, and api_smoke_test.py.
#
# This file is only an example. Put real credentials in .env, which is ignored
# by git.

# Full OpenAI-compatible chat-completions endpoint or provider base URL.
PURE_JADE_API_URL=https://api.openai.com/v1/chat/completions

# Required. Never commit a real key.
PURE_JADE_API_KEY=replace-with-your-api-key

# Required. Replace with the model name provided by your API supplier.
PURE_JADE_API_MODEL=replace-with-your-model

# Optional.
PURE_JADE_API_TEMPERATURE=0.2
PURE_JADE_API_TIMEOUT_SECONDS=60
PURE_JADE_API_MAX_RETRIES=1

# Set to 0 if your provider does not support response_format={"type":"json_object"}.
PURE_JADE_API_JSON_MODE=1
